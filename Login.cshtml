@model BDTechMarket.Models.ViewModels.LoginVM
@{
    ViewData["Title"] = "Sign In";
    var returnUrl = Context.Request.Query["ReturnUrl"];
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white text-center py-4 border-0">
                    <i class="fas fa-shield-alt fa-3x mb-2"></i>
                    <h3 class="fw-bold mb-0">Welcome Back</h3>
                    <p class="small mb-0 text-white-50">Please sign in to continue shopping</p>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <form asp-action="Login" asp-route-returnurl="@returnUrl" method="post">
                        
                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                        {
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small py-2 mb-4 shadow-sm"></div>
                        }

                        <div class="form-floating mb-3">
                            <input asp-for="Username" class="form-control border-1 shadow-none" id="loginUsername" placeholder="Enter Username" required />
                            <label asp-for="Username" for="loginUsername">Username</label>
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Password" class="form-control border-1 shadow-none" id="loginPassword" placeholder="Password" />
                            <label asp-for="Password" for="loginPassword">Password</label>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox">
                                <label asp-for="RememberMe" class="form-check-label text-muted small">Stay logged in</label>
                            </div>
                            <a href="#" class="small text-decoration-none">Forgot Password?</a>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm py-3 transition-transform">
                                <i class="fas fa-sign-in-alt me-2"></i> Sign In
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer text-center bg-light border-0 py-3">
                    <p class="small mb-0 text-muted">
                        Don't have an account? <a asp-action="Register" class="text-primary text-decoration-none fw-bold">Sign Up Now</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}