@{
    ViewData["Title"] = "Order Successful";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden text-center p-4 p-md-5 animate__animated animate__backInUp">
                
                @* Success Icon with Custom Animation *@
                <div class="mb-4 d-flex justify-content-center">
                    <div class="success-checkmark">
                        <div class="check-icon">
                            <span class="icon-line line-tip"></span>
                            <span class="icon-line line-long"></span>
                            <div class="icon-circle"></div>
                            <div class="icon-fix"></div>
                        </div>
                    </div>
                </div>

                <h1 class="display-6 fw-bold text-dark mb-2">Thank You for Your Order!</h1>
                <p class="lead text-muted mb-4">
                    Your order has been placed and is currently being processed.
                </p>

                @* Order Summary Card *@
                <div class="card bg-light border-0 rounded-3 mb-4">
                    <div class="card-body py-3 px-4">
                        <div class="row align-items-center">
                            <div class="col-sm-6 text-sm-start mb-2 mb-sm-0">
                                <span class="text-muted small d-block">Order Number</span>
                                <span class="fw-bold text-primary">#ORD-@ViewBag.OrderId.ToString("D5")</span>
                            </div>
                            <div class="col-sm-6 text-sm-end">
                                <a asp-controller="Order" asp-action="Invoice" asp-route-id="@ViewBag.OrderId" target="_blank" class="btn btn-sm btn-outline-success rounded-pill">
                                    <i class="fas fa-file-invoice me-1"></i> Print Invoice
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                @* Order Journey Timeline *@
                
                <div class="order-journey mb-5 text-start px-3">
                    <h6 class="fw-bold text-uppercase small text-muted mb-4 text-center">What's Next?</h6>
                    <div class="d-flex justify-content-between position-relative timeline-line">
                        <div class="text-center z-1">
                            <div class="step-icon bg-success text-white mb-2 mx-auto"><i class="fas fa-clipboard-check"></i></div>
                            <span class="x-small fw-bold">Confirmed</span>
                        </div>
                        <div class="text-center z-1">
                            <div class="step-icon bg-white border text-muted mb-2 mx-auto"><i class="fas fa-box"></i></div>
                            <span class="x-small">Packaging</span>
                        </div>
                        <div class="text-center z-1">
                            <div class="step-icon bg-white border text-muted mb-2 mx-auto"><i class="fas fa-shipping-fast"></i></div>
                            <span class="x-small">On the Way</span>
                        </div>
                        <div class="text-center z-1">
                            <div class="step-icon bg-white border text-muted mb-2 mx-auto"><i class="fas fa-home"></i></div>
                            <span class="x-small">Delivered</span>
                        </div>
                    </div>
                </div>

                @* Action Buttons *@
                <div class="row g-3">
                    <div class="col-sm-6">
                        <a asp-controller="Order" asp-action="MyOrders" class="btn btn-primary w-100 btn-lg rounded-pill fw-bold shadow-sm transition-hover">
                            Track My Order
                        </a>
                    </div>
                    <div class="col-sm-6">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark w-100 btn-lg rounded-pill transition-hover">
                            Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
            
            <p class="text-center mt-4 text-muted small">
                Need help? Contact us at <a href="mailto:support@bdtechmarket.com" class="text-decoration-none">support@bdtechmarket.com</a>
            </p>
        </div>
    </div>
</div>

<style>
    body { background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh; }
    .x-small { font-size: 10px; text-transform: uppercase; }
    .rounded-4 { border-radius: 1.5rem !important; }
    
    /* Timeline Styling */
    .step-icon { width: 40px; height: 40px; line-height: 40px; border-radius: 50%; font-size: 16px; position: relative; }
    .timeline-line::after {
        content: ""; position: absolute; top: 20px; left: 10%; right: 10%;
        height: 2px; background: #dee2e6; z-index: 0;
    }

    /* Custom Checkmark Animation */
    .success-checkmark { width: 80px; height: 115px; margin: 0 auto; }
    .check-icon { width: 80px; height: 80px; position: relative; border-radius: 50%; box-sizing: content-box; border: 4px solid #4CAF50; }
    .check-icon::before, .check-icon::after { content: ''; position: absolute; background: #ffffff; }
    .icon-line { height: 5px; background-color: #4CAF50; display: block; border-radius: 2px; position: absolute; z-index: 10; }
    .line-tip { top: 46px; left: 14px; width: 25px; transform: rotate(45deg); }
    .line-long { top: 38px; right: 8px; width: 47px; transform: rotate(-45deg); }
    
    .transition-hover { transition: all 0.3s ease; }
    .transition-hover:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
    
    footer { display: none !important; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
    <script>
        // Trigger Confetti on Load
        window.onload = function() {
            var duration = 3 * 1000;
            var end = Date.now() + duration;

            (function frame() {
              confetti({
                particleCount: 3,
                angle: 60,
                spread: 55,
                origin: { x: 0 },
                colors: ['#28a745', '#ffc107']
              });
              confetti({
                particleCount: 3,
                angle: 120,
                spread: 55,
                origin: { x: 1 },
                colors: ['#28a745', '#ffc107']
              });

              if (Date.now() < end) {
                requestAnimationFrame(frame);
              }
            }());
        };
    </script>
}