@model IEnumerable<BDTechMarket.Models.Product>
@{
    ViewData["Title"] = "Gadget Market";
}

<div class="container py-4">
    @* --- Header & Admin Button --- *@
    <div class="row align-items-end mb-4 g-3">
        <div class="col-md-8">
            <h2 class="fw-bold text-dark border-start border-5 border-primary ps-3 mb-1">Tech Catalog</h2>
            <p class="text-muted small ps-3 mb-0">Browsing @Model.Count() authentic gadgets in stock</p>
        </div>
        <div class="col-md-4 text-md-end">
            @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-dark rounded-pill px-4 shadow-sm fw-bold">
                    <i class="fas fa-plus-circle me-2"></i>Inventory Entry
                </a>
            }
        </div>
    </div>

    @* --- Search & Filter Bar --- *@
    <div class="search-bar-container bg-white shadow-sm rounded-pill p-2 mb-5 border">
        <form asp-action="Index" method="get" class="row g-0 align-items-center">
            <div class="col-md-5 px-3 border-end">
                <div class="d-flex align-items-center">
                    <i class="fas fa-search text-muted me-2"></i>
                    <input type="text" name="searchString" class="form-control border-0 shadow-none bg-transparent" 
                           placeholder="Search gadgets..." value="@Context.Request.Query["searchString"]" />
                </div>
            </div>
            <div class="col-md-4 px-3">
                <select name="categoryId" class="form-select border-0 shadow-none bg-transparent" asp-items="ViewBag.Categories">
                    <option value="">All Categories</option>
                </select>
            </div>
            <div class="col-md-3 text-end">
                <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Filter</button>
            </div>
        </form>
    </div>

    @* --- Product Grid --- *@
    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="empty-state">
                    <i class="fas fa-microchip fa-4x text-muted opacity-25 mb-3"></i>
                    <h4 class="text-muted">Oops! No tech here.</h4>
                    <p class="text-muted">Try adjusting your filters or search terms.</p>
                    <a asp-action="Index" class="btn btn-outline-primary rounded-pill mt-2">Clear All Filters</a>
                </div>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-xl-3 col-lg-4 col-sm-6">
                    <div class="card h-100 border-0 shadow-sm rounded-4 product-card">
                        @* Image Section *@
                        <div class="card-img-wrapper position-relative overflow-hidden bg-white d-flex align-items-center justify-content-center">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@Url.Content(item.ImageUrl)" class="main-img" alt="@item.Name" />
                            }
                            else
                            {
                                <div class="text-center opacity-25 py-5">
                                    <i class="fas fa-box-open fa-3x"></i>
                                </div>
                            }
                            
                            @* Badges *@
                            <div class="position-absolute top-0 start-0 m-3 d-flex flex-column gap-1">
                                @if (item.Price > 70000)
                                {
                                    <span class="badge bg-dark rounded-pill shadow-sm small">Flagship</span>
                                }
                                <span class="badge bg-warning text-dark rounded-pill shadow-sm small">New</span>
                            </div>
                        </div>

                        <div class="card-body p-3 d-flex flex-column">
                            <small class="text-uppercase text-primary fw-bold x-small mb-1">@(item.Category?.Name ?? "General")</small>
                            <h6 class="fw-bold text-dark text-truncate-2 mb-2" title="@item.Name">@item.Name</h6>
                            
                            <div class="mt-auto pt-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="price-stack">
                                        <h5 class="text-dark fw-bold mb-0">৳@item.Price.ToString("N0")</h5>
                                        <p class="text-muted x-small mb-0"><i class="fas fa-shipping-fast"></i> Free Delivery</p>
                                    </div>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-light rounded-circle shadow-sm">
                                        <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>

                        @* Admin Actions Overlay (Only visible on hover) *@
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <div class="admin-actions p-2 bg-dark bg-opacity-75 d-flex justify-content-center gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning rounded-pill"><i class="fas fa-edit"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger rounded-pill"><i class="fas fa-trash"></i></a>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    :root { --primary-color: #0d6efd; }
    .x-small { font-size: 0.7rem; }
    .product-card { transition: all 0.3s cubic-bezier(.25,.8,.25,1); }
    .product-card:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important; }
    
    .card-img-wrapper { height: 220px; border-radius: 1rem 1rem 0 0; }
    .main-img { max-height: 180px; width: auto; max-width: 90%; object-fit: contain; transition: 0.4s ease; }
    .product-card:hover .main-img { transform: scale(1.08); }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 2.8rem;
    }

    .admin-actions {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        transform: translateY(100%);
        transition: 0.3s ease;
    }
    .product-card:hover .admin-actions { transform: translateY(0); }
    
    .search-bar-container { max-width: 900px; margin: 0 auto; }
</style>