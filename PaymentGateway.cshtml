@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Secure Checkout - BDTechMarket</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body { background: #e9ecef; font-family: 'Inter', sans-serif; }
        .pay-card { max-width: 420px; margin: 50px auto; border-radius: 15px; box-shadow: 0 20px 40px rgba(0,0,0,0.15); border:none; background: #fff; }
        
        /* Dynamic Brand Header */
        .brand-header { padding: 30px; text-align: center; border-radius: 15px 15px 0 0; position: relative; }
        .bkash { background: #D12053; }
        .nagad { background: #F7941E; }
        .card-pay { background: #1a2a6c; }
        
        .brand-logo { height: 45px; margin-bottom: 10px; filter: brightness(0) invert(1); }
        .form-control-custom { height: 55px; font-size: 1.2rem; font-weight: 600; letter-spacing: 2px; border: 2px solid #eee; }
        .form-control-custom:focus { border-color: #000; box-shadow: none; }
        
        /* Spinner Overlay */
        #loader { display:none; position: absolute; top:0; left:0; width:100%; height:100%; background: rgba(255,255,255,0.9); z-index: 10; display:flex; align-items:center; justify-content:center; flex-direction:column; border-radius: 15px; }
    </style>
</head>
<body>

<div class="card pay-card">
    @* --- Processing Overlay --- *@
    <div id="loader" style="display:none;">
        <div class="spinner-border text-primary mb-3" role="status"></div>
        <span class="fw-bold">Verifying with Bank...</span>
    </div>

    @* --- Header Section --- *@
    <div class="brand-header @(ViewBag.Method == "bKash" ? "bkash" : ViewBag.Method == "Nagad" ? "nagad" : "card-pay") text-white">
        <h5 class="mb-0 fw-bold">@ViewBag.Method Secure Payment</h5>
        <div class="mt-3">
            <h2 class="mb-0">৳ @ViewBag.Amount</h2>
            <p class="small opacity-75">Order ID: #ORD-@ViewBag.OrderId.ToString("D5")</p>
        </div>
    </div>
    
    <div class="card-body p-4">
        @* --- Payment Form Logic --- *@
        @if(ViewBag.Method == "Card") {
            <div id="cardUI">
                <label class="small text-muted mb-1">Card Number</label>
                <input type="text" id="cardNo" class="form-control form-control-custom mb-3" placeholder="XXXX XXXX XXXX XXXX">
                <div class="row g-2">
                    <div class="col-6">
                        <label class="small text-muted mb-1">Expiry</label>
                        <input type="text" class="form-control" placeholder="MM/YY">
                    </div>
                    <div class="col-6">
                        <label class="small text-muted mb-1">CVV/PIN</label>
                        <input type="password" id="cvv" class="form-control" placeholder="123" maxlength="3">
                    </div>
                </div>
                <button onclick="simulateProcess('card')" class="btn btn-dark w-100 py-3 mt-4 fw-bold">AUTHORIZE PAYMENT</button>
            </div>
        } else {
            <div id="mfsStep1">
                <label class="small text-muted mb-2">Your @ViewBag.Method Account Number</label>
                <input type="text" id="phone" class="form-control form-control-custom" placeholder="01XXXXXXXXX" maxlength="11">
                <button onclick="goPin()" class="btn btn-dark w-100 py-3 mt-3 fw-bold">PROCEED</button>
            </div>
            <div id="mfsStep2" style="display:none;">
                <label class="small text-muted mb-2">Enter 4-Digit Secret PIN</label>
                <input type="password" id="pin" class="form-control form-control-custom text-center" placeholder="****" maxlength="4">
                <button onclick="simulateProcess('mfs')" class="btn btn-success w-100 py-3 mt-3 fw-bold">CONFIRM PAYMENT</button>
            </div>
        }

        @* --- Security Footer --- *@
        <div class="text-center mt-4 pt-3 border-top">
            <div class="d-flex justify-content-center gap-3 opacity-50 mb-2">
                <i class="fas fa-shield-alt"></i>
                <i class="fas fa-lock"></i>
                <i class="fas fa-check-double"></i>
            </div>
            <small class="text-muted" style="font-size: 10px;">
                Your payment is encrypted and secured by SSL Wireless. 
                BDTechMarket does not store your PIN or CVV.
            </small>
        </div>
    </div>
</div>

<script>
    function goPin() {
        let ph = document.getElementById('phone').value;
        if(ph.length === 11) {
            document.getElementById('mfsStep1').classList.add('animate__animated', 'animate__fadeOut');
            setTimeout(() => {
                document.getElementById('mfsStep1').style.display='none';
                document.getElementById('mfsStep2').style.display='block';
            }, 300);
        } else { alert("Enter valid number"); }
    }

    function simulateProcess(type) {
        document.getElementById('loader').style.display = 'flex';
        
        // Simulate a network delay of 2 seconds
        setTimeout(() => {
            handlePayment(type);
        }, 2000);
    }

    function handlePayment(type) {
        let pin = (type === 'mfs') ? document.getElementById('pin').value : document.getElementById('cvv').value;
        let balance = 5000;
        let bill = @ViewBag.Amount;

        if(pin === "1234" || (type === 'card' && pin.length === 3)) {
            if(balance < bill) {
                document.getElementById('loader').style.display = 'none';
                alert("❌ Transaction Failed: Insufficient Balance!");
            } else {
                window.location.href = '/Order/OrderSuccess?id=' + @ViewBag.OrderId;
            }
        } else {
            document.getElementById('loader').style.display = 'none';
            alert("❌ Security Check Failed: Invalid PIN/CVV.");
        }
    }
</script>

</body>
</html>